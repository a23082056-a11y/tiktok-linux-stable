{
  "app-id": "com.Arsen.TikTokDesktop",
  "runtime": "org.gnome.Platform",
  "runtime-version": "45",
  "sdk": "org.gnome.Sdk",
  "command": "/app/bin/tiktok_app.py",
  "build-options": {
    "build-args": ["--share=network"]
  },
  "finish-args": [
    "--share=ipc",
    "--socket=x11",
    "--socket=wayland",
    "--share=network",
    "--device=all",
    "--filesystem=home"
  ],
  "modules": [
    {
      "name": "python3-requirements",
      "buildsystem": "simple",
      "build-commands": [
        "pip3 install --prefix=/app PyQt6 PyQt6-WebEngine"
      ]
    },
    {
      "name": "tiktok-app",
      "buildsystem": "simple",
      "build-commands": [
        "install -D tiktok_app.py /app/bin/tiktok_app.py",
        "install -D tiktok_icon.png /app/share/icons/hicolor/512x512/apps/com.Arsen.TikTokDesktop.png"
      ],
      "sources": [
        { "type": "file", "path": "tiktok_app.py" },
        { "type": "file", "path": "tiktok_icon.png" }
      ]
    }
  ]
}
